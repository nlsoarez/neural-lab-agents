# Neural Lab — Environment Variables
# Copie este arquivo como .env e preencha os valores
# NUNCA commite o .env com valores reais no Git

# =============================================================
# OBRIGATORIO — Sem estas variaveis o sistema nao funciona
# =============================================================

# OpenAI API (Codex local adapter + GPT-Image-2 para geracao de imagens)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Paperclip Auth Secret (gere com: openssl rand -hex 32)
BETTER_AUTH_SECRET=seu_secret_aleatorio_de_32_chars_aqui

# Database (Railway PostgreSQL — copiar da dashboard do Railway)
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# =============================================================
# RECOMENDADO — Habilita funcionalidades de pesquisa de mercado
# =============================================================

# SerpAPI (Google Search + Google Trends)
# https://serpapi.com — $75/mes Developer plan
SERPAPI_KEY=seu_serpapi_key_aqui

# Serper.dev (alternativa mais barata ao SerpAPI)
# https://serper.dev
SERPER_API_KEY=seu_serper_key_aqui

# =============================================================
# GERACAO DE IMAGENS — OpenAI GPT-Image-2 (via OPENAI_API_KEY acima)
# Modelo fixo do Social Media & Design Agent. Nao trocar sem decisao humana.
# Config padrao: quality=standard, max 3 imagens por execucao semanal.
# Resolucoes alvo: 1024x1024 | 1024x1792
# =============================================================

OPENAI_IMAGE_MODEL=gpt-image-2

# =============================================================
# FASE 2 — Imagens alternativas (opcional, modelos abertos)
# Use se quiser Flux ou SDXL alem do GPT-Image-2
# =============================================================

# Replicate API (Flux, SDXL, Stable Diffusion)
# https://replicate.com
REPLICATE_API_TOKEN=r8_...

# Fal.ai (Flux ultra-rapido)
# https://fal.ai
FAL_API_KEY=...

# =============================================================
# TELEGRAM — Bot + Gateway bidirecional
# =============================================================

# Telegram Bot Token (criar em: t.me/BotFather)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Telegram Gateway (servico separado no Railway)
TELEGRAM_WEBHOOK_SECRET=...
PAPERCLIP_AUTH_TOKEN=...
GATEWAY_PORT=3200

# Notion API (para publicar relatorios no Notion)
# https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# =============================================================
# CONFIGURACAO DO SERVIDOR
# =============================================================

PORT=3100
HOST=0.0.0.0
NODE_ENV=production

# Paperclip Configuration
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=neural-lab
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
PAPERCLIP_PUBLIC_URL=https://neural-lab.up.railway.app

# Caminho absoluto usado pelos adapters locais dentro do container Railway.
NEURAL_LAB_WORKSPACE=/app/neural-lab-agents

# Timezone (important for heartbeat schedules — BRT = UTC-3)
TZ=America/Sao_Paulo
