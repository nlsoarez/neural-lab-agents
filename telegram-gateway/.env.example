# ── Required ──────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Numeric chat ID (positive for private, negative for groups)
TELEGRAM_CHAT_ID=

# Auth token for the Paperclip API
PAPERCLIP_AUTH_TOKEN=

# ── Optional ──────────────────────────────────────────────

# Where to reach Paperclip (default: http://localhost:3100)
PAPERCLIP_API_URL=

# Header secret Telegram sends with each webhook (set in setWebhook).
# Compared with timingSafeEqual — leave empty to disable the check.
TELEGRAM_WEBHOOK_SECRET=

# HTTP port (default 3200). Railway provides PORT automatically.
GATEWAY_PORT=

# ── Tunables (all have safe defaults) ─────────────────────

# Max commands accepted per minute across all users
RATE_LIMIT_PER_MINUTE=10

# How often to poll an open issue for updates
POLL_INTERVAL_MS=30000

# Give up waiting for an agent after this long
POLL_TIMEOUT_MS=600000

# Treat issue as done when the latest comment has been idle this long
# AND no new comments arrived since the previous poll
POLL_STABLE_AFTER_MS=60000

# Truncate agent output to fit in a Telegram message (hard limit 4096)
TELEGRAM_MAX_MESSAGE_LEN=3800

# Truncate user input before passing to the LLM (caps token cost)
COMMAND_MAX_INPUT_LEN=4000

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
